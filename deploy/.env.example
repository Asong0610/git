# ============================================================
# Campus Device API — 环境变量模板
# ============================================================
# 使用方式：
#   cp deploy/.env.example deploy/.env
#   然后编辑 deploy/.env 填入真实的连接信息
#
# 注意：deploy/.env 包含敏感信息，已被 .gitignore 忽略，
#       请勿将真实密码提交到版本控制。
# ============================================================

# MySQL / MariaDB 数据库连接（支持腾讯云 CDB）
# 格式：mysql+pymysql://用户名:密码@主机:端口/数据库名
DATABASE_URL=mysql+pymysql://campus:campus@127.0.0.1:3306/campus_device

# Redis 缓存（阶段 2 使用）
REDIS_URL=redis://127.0.0.1:6379/0

# JWT 认证（阶段 2 使用）
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# 应用运行模式
APP_ENV=development
APP_DEBUG=true
